<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.OpeningScreenController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="800.0"
                    prefHeight="550.0"
                    minWidth="650.0"
                    minHeight="500.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="26.0"
                      styleClass="page-container">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Welcome to GoNature"
                                       styleClass="page-title"/>

                                <Label text="Please choose your login type"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="440.0"/>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER" spacing="28.0">
                            <children>

                                <VBox alignment="CENTER"
                                      spacing="16.0"
                                      prefWidth="280.0"
                                      maxWidth="280.0"
                                      styleClass="card">

                                    <children>
                                        <Label text="For Employees"
                                               styleClass="section-title"/>

                                        <Label text="Login with your employee account"
                                               wrapText="true"
                                               textAlignment="CENTER"
                                               styleClass="page-subtitle"/>

                                        <Button fx:id="employeeLoginBtn"
                                                text="Employee Login"
                                                prefWidth="220.0"
                                                styleClass="primary-button"
                                                onAction="#handleEmployeeLogin"/>
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER"
                                      spacing="16.0"
                                      prefWidth="280.0"
                                      maxWidth="280.0"
                                      styleClass="card">

                                    <children>
                                        <Label text="For Customers"
                                               styleClass="section-title"/>

                                        <Label text="Access existing or occasional customer options"
                                               wrapText="true"
                                               textAlignment="CENTER"
                                               styleClass="page-subtitle"/>

                                        <Button fx:id="customerAccessBtn"
                                                text="Customer Access"
                                                prefWidth="220.0"
                                                styleClass="secondary-button"
                                                onAction="#handleCustomerAccess"/>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>