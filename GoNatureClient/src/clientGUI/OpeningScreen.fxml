<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGUI.OpeningScreenController">
   <children>
      <AnchorPane layoutX="-3.0" prefHeight="450.0" prefWidth="700.0">
         <children>
            <Label layoutX="205.0" layoutY="74.0" text="Welcome to GoNature">
               <font>
                  <Font name="System Bold Italic" size="28.0" />
               </font>
            </Label>
            <Label layoutX="245.0" layoutY="140.0" text="Please choose your login type">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <Button fx:id="employeeLoginBtn" layoutX="106.0" layoutY="263.0" mnemonicParsing="false" onAction="#handleEmployeeLogin" prefHeight="50.0" prefWidth="220.0" text="Employee Login" />
            <Button fx:id="customerAccessBtn" layoutX="386.0" layoutY="263.0" mnemonicParsing="false" onAction="#handleCustomerAccess" prefHeight="50.0" prefWidth="220.0" text="Customer Access" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
