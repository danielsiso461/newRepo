<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="clientGUI.WaitingListController">

   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

   <children>

      <!-- Page title. -->
      <Label text="My Waiting List">
         <font>
            <Font size="28.0" />
         </font>
      </Label>

      <!-- Table that displays active waiting list requests. -->
      <TableView fx:id="offersTable" prefHeight="330.0" prefWidth="850.0">
         <columns>
            <TableColumn fx:id="waitingIdColumn" prefWidth="100.0" text="Waiting ID" />
            <TableColumn fx:id="parkIdColumn" prefWidth="100.0" text="Park ID" />
            <TableColumn fx:id="requestedDateColumn" prefWidth="220.0" text="Requested Date" />
            <TableColumn fx:id="visitorsColumn" prefWidth="120.0" text="Visitors" />
            <TableColumn fx:id="queuePositionColumn" prefWidth="150.0" text="Queue Position" />
            <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Status" />
         </columns>
      </TableView>

      <!-- Buttons for handling the selected offered request. -->
      <HBox alignment="CENTER" spacing="15.0">
         <children>

            <!-- Accepts the selected offered waiting list request. -->
            <Button fx:id="acceptButton"
                    mnemonicParsing="false"
                    onAction="#acceptSelectedOfferClick"
                    text="Accept Offer">
               <font>
                  <Font size="16.0" />
               </font>
            </Button>

            <!-- Rejects the selected offered waiting list request. -->
            <Button fx:id="rejectButton"
                    mnemonicParsing="false"
                    onAction="#rejectSelectedOfferClick"
                    text="Reject Offer">
               <font>
                  <Font size="16.0" />
               </font>
            </Button>

            <!-- Returns to the order table page. -->
            <Button fx:id="backButton"
                    mnemonicParsing="false"
                    onAction="#backButtonClick"
                    text="Back">
               <font>
                  <Font size="16.0" />
               </font>
            </Button>

         </children>
      </HBox>

      <!-- Displays success, failure and validation messages. -->
      <Label fx:id="messageLabel" wrapText="true" maxWidth="850.0">
         <font>
            <Font size="16.0" />
         </font>
      </Label>

   </children>
</VBox>