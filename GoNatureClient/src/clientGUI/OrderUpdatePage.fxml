<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.OrderUpdateController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="850.0"
                    prefHeight="600.0"
                    minWidth="750.0"
                    minHeight="500.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER" spacing="24.0" styleClass="page-container">
                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label text="Update Order" styleClass="page-title"/>
                                <Label text="Choose which order details you want to update"
                                       styleClass="page-subtitle"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="18.0" maxWidth="620.0" styleClass="card">
                            <children>

                                <HBox styleClass="form-row">
                                    <children>
                                        <Label text="Order date" minWidth="180.0" styleClass="field-label"/>
                                        <DatePicker fx:id="OrderUpdatePageDatePicker" prefWidth="240.0"/>
                                        <CheckBox fx:id="OrderUpdatePageDateCheckBox" text="Update Date"/>
                                    </children>
                                </HBox>

                                <HBox styleClass="form-row">
                                    <children>
                                        <Label text="Number of visitors" minWidth="180.0" styleClass="field-label"/>
                                        <Spinner fx:id="OrderUpdatePageSpinner"
                                                 editable="false"
                                                 prefWidth="240.0"/>
                                        <CheckBox fx:id="OrderUpdatePageVisitorsCheckBox" text="Update Visitors"/>
                                    </children>
                                </HBox>

                                <Region prefHeight="10.0"/>

                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button fx:id="OrderUpdatePageUpdateButton"
                                                text="Update"
                                                prefWidth="150.0"
                                                styleClass="primary-button"
                                                onAction="#OrderUpdatePageUpdateButtonHandler"/>

                                        <Button fx:id="OrderUpdatePageCancelButton"
                                                text="Cancel"
                                                prefWidth="150.0"
                                                styleClass="secondary-button"
                                                onAction="#OrderUpdatePageCancelButtonHandler"/>
                                    </children>
                                </HBox>

                                <Label fx:id="updateLabel"
								       text=""
								       visible="false"
								       managed="false"
								       styleClass="status-label"/>

                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>