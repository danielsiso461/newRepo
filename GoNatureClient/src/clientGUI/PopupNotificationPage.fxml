<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.PopupNotificationPageController"
            prefWidth="430.0"
            prefHeight="280.0"
            style="-fx-background-color: #f7f7f7;">

    <children>
        <VBox spacing="14.0"
              alignment="TOP_CENTER"
              AnchorPane.topAnchor="20.0"
              AnchorPane.leftAnchor="25.0"
              AnchorPane.rightAnchor="25.0"
              AnchorPane.bottomAnchor="20.0">

            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>

            <Label text="Simulation"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />

            <Label fx:id="titleLabel"
                   text="Notification Title"
                   wrapText="true"
                   style="-fx-font-size: 17px; -fx-font-weight: bold;" />

            <Label fx:id="bodyLabel"
                   text="Notification body"
                   wrapText="true"
                   prefWidth="350.0"
                   style="-fx-font-size: 14px;" />

            <Label fx:id="emailLabel"
                   text="Email:"
                   wrapText="true"
                   prefWidth="350.0"
                   style="-fx-font-size: 12px;" />

            <Label fx:id="phoneLabel"
                   text="Phone:"
                   wrapText="true"
                   prefWidth="350.0"
                   style="-fx-font-size: 12px;" />

            <Button text="OK"
                    prefWidth="100.0"
                    onAction="#handleClose" />

        </VBox>
    </children>
</AnchorPane>