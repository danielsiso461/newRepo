<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.ParkManagerHomePageController"
            stylesheets="@gonature-theme.css"
            styleClass="page-background">

    <children>
        <VBox alignment="CENTER"
              spacing="18.0"
              prefWidth="700.0"
              prefHeight="450.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <children>
                <Label text="Park Manager Dashboard"
                       styleClass="page-title"/>

                <Label fx:id="welcomeLabel"
                       text="Welcome"
                       styleClass="page-subtitle"/>

                <Button text="Request Park Parameter Change"
                        prefWidth="240.0"
                        mnemonicParsing="false"
                        styleClass="primary-button"
                        onAction="#handleRequestParameterChange"/>

                <Button text="View Park Reports"
                        prefWidth="240.0"
                        mnemonicParsing="false"
                        styleClass="secondary-button"
                        onAction="#handleViewParkReports"/>

                <Button text="View Park Orders"
                        prefWidth="240.0"
                        mnemonicParsing="false"
                        styleClass="secondary-button"
                        onAction="#handleViewParkOrders"/>

                <Button text="View User Information"
                        prefWidth="240.0"
                        mnemonicParsing="false"
                        styleClass="secondary-button"
                        onAction="#handleViewUserInformation"/>

                <Button text="Logout"
                        prefWidth="240.0"
                        mnemonicParsing="false"
                        styleClass="secondary-button"
                        onAction="#handleLogout"/>
            </children>
        </VBox>
    </children>
</AnchorPane>