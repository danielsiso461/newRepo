<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGUI.EmployeeLoginController">
   <children>
      <AnchorPane layoutX="-3.0" layoutY="-4.0" prefHeight="450.0" prefWidth="700.0">
         <children>
            <Label layoutX="255.0" layoutY="60.0" text="Employee Login" textAlignment="JUSTIFY">
               <font>
                  <Font name="System Italic" size="28.0" />
               </font>
            </Label>
            <Label layoutX="221.0" layoutY="118.0" text="Please enter your employee credentials">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Label layoutX="221.0" layoutY="168.0" text="Username:" />
            <TextField fx:id="usernameField" layoutX="331.0" layoutY="164.0" promptText="Enter username" />
            <Label layoutX="221.0" layoutY="225.0" text="Password:" />
            <Button fx:id="loginBtn" layoutX="195.0" layoutY="307.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" prefWidth="120.0" text="Login" />
            <Button fx:id="backBtn" layoutX="386.0" layoutY="307.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="40.0" prefWidth="120.0" text="Back" />
            <Label fx:id="messageLabel" layoutX="195.0" layoutY="385.0" />
            <PasswordField fx:id="passwordField" layoutX="331.0" layoutY="221.0" promptText="Enter password" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
