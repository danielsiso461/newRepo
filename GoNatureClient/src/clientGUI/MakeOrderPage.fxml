<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.MakeOrderPageController"
            stylesheets="@gonature-theme.css"
            styleClass="page-background">

    <children>
        <BorderPane prefWidth="850.0"
                    prefHeight="620.0"
                    minWidth="700.0"
                    minHeight="560.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="card-container"
                      maxWidth="1.7976931348623157E308"
                      maxHeight="1.7976931348623157E308">

                    <children>

                        <VBox alignment="CENTER" spacing="10.0" styleClass="page-header">
                            <children>
                                <Label text="Make New Order"
                                       styleClass="page-title"/>

                                <Label text="Fill in the visit details and submit your order"
                                       styleClass="page-subtitle"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="18.0"
                              maxWidth="620.0"
                              styleClass="content-card">

                            <children>

                                <GridPane hgap="18.0" vgap="14.0">

                                    <children>
                                        <Label text="Park:"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="0"/>

                                        <ComboBox fx:id="parkPicker"
                                                  prefWidth="260.0"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="0"/>

                                        <Label text="Visit Date:"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="1"/>

                                        <DatePicker fx:id="datePicker"
                                                    prefWidth="260.0"
                                                    GridPane.columnIndex="1"
                                                    GridPane.rowIndex="1"/>

                                        <Label text="Visit Hour:"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="2"/>

                                        <ComboBox fx:id="hourPicker"
                                                  prefWidth="260.0"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="2"/>

                                        <HBox fx:id="visitorNumberRow"
                                              spacing="18.0"
                                              GridPane.columnIndex="0"
                                              GridPane.rowIndex="3"
                                              GridPane.columnSpan="2">
                                            <children>
                                                <Label text="Number of Visitors:"
                                                       minWidth="140.0"/>

                                                <Spinner fx:id="visitorNumberPicker"
                                                         prefWidth="260.0"/>
                                            </children>
                                        </HBox>

                                        <Label text="Email:"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="4"/>

                                        <TextField fx:id="email"
                                                   prefWidth="260.0"
                                                   promptText="Enter email"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="4"/>

                                        <CheckBox fx:id="guideCheckbox"
                                                  text="Organized visit with guide"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="5"/>
                                    </children>
                                </GridPane>

                                <HBox alignment="CENTER" spacing="18.0">
                                    <children>
                                        <Button fx:id="makeOrderButton"
                                                text="Submit Order"
                                                prefWidth="160.0"
                                                styleClass="primary-button"
                                                onAction="#makeOrderButtonClicked"/>

                                        <Button text="Back"
                                                prefWidth="120.0"
                                                styleClass="secondary-button"
                                                onAction="#handleBack"/>
                                    </children>
                                </HBox>

                                <ButtonBar fx:id="buttonBar">
                                    <buttons>
                                        <Button fx:id="enterWaitingListButton"
                                                text="Enter Waiting List"
                                                onAction="#enterWaitingListButtonClicked"/>

                                        <Button fx:id="rescheduleButton"
                                                text="Reschedule"
                                                onAction="#rescheduleButtonClicked"/>
                                    </buttons>
                                </ButtonBar>

                                <Label fx:id="errorLabel"
                                       text=""
                                       wrapText="true"
                                       maxWidth="520.0"
                                       styleClass="status-label"/>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>