<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.ParkVisitorCounterViewPageController"
            stylesheets="@gonature-theme.css">

    <styleClass>
        <String fx:value="root-pane"/>
    </styleClass>

    <children>
        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      maxWidth="950.0">

                    <styleClass>
                        <String fx:value="page-container"/>
                    </styleClass>

                    <padding>
                        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
                    </padding>

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Park Visitor Counter">
                                    <styleClass>
                                        <String fx:value="page-title"/>
                                    </styleClass>
                                </Label>

                                <Label text="View real-time visitor count in the park">
                                    <styleClass>
                                        <String fx:value="page-subtitle"/>
                                    </styleClass>
                                </Label>
                            </children>
                        </VBox>

                        <VBox spacing="18.0"
                              maxWidth="820.0">

                            <styleClass>
                                <String fx:value="card"/>
                            </styleClass>

                            <padding>
                                <Insets top="24.0" right="28.0" bottom="24.0" left="28.0"/>
                            </padding>

                            <children>

                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="refreshButton"
                                                text="Refresh"
                                                prefWidth="120.0"
                                                onAction="#handleRefresh">
                                            <styleClass>
                                                <String fx:value="secondary-button"/>
                                            </styleClass>
                                        </Button>
                                    </children>
                                </HBox>

                                <TableView fx:id="counterTableView"
                                           prefHeight="360.0">

                                    <columns>
                                        <TableColumn fx:id="parkNameColumn"
                                                     text="Park"
                                                     prefWidth="250.0"/>

                                        <TableColumn fx:id="currentVisitorsColumn"
                                                     text="Current Visitors"
                                                     prefWidth="170.0"/>

                                        <TableColumn fx:id="maxCapacityColumn"
                                                     text="Max Capacity"
                                                     prefWidth="160.0"/>

                                        <TableColumn fx:id="availablePlacesColumn"
                                                     text="Available Places"
                                                     prefWidth="170.0"/>
                                    </columns>
                                </TableView>

                            </children>
                        </VBox>

                        <Label fx:id="statusLabel"
                               text="Status: Ready">
                            <styleClass>
                                <String fx:value="status-label"/>
                                <String fx:value="status-info"/>
                            </styleClass>
                        </Label>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>