<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.ParkVisitorCounterViewPageController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="1050.0"
                    prefHeight="720.0"
                    minWidth="850.0"
                    minHeight="580.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="58.0"
                      style="-fx-padding: 16 24 0 24;">
                    <children>
                        <Button text="Back"
                                prefWidth="110.0"
                                styleClass="back-button"
                                onAction="#handleBack"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER"
                      spacing="22.0"
                      styleClass="page-container"
                      maxWidth="Infinity"
                      maxHeight="Infinity">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Park Visitor Counter"
                                       styleClass="page-title"/>

                                <Label text="View real-time visitor count in each park"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="560.0"/>
                            </children>
                        </VBox>

                        <VBox spacing="16.0"
                              maxWidth="950.0"
                              maxHeight="Infinity"
                              styleClass="card"
                              VBox.vgrow="ALWAYS">

                            <children>

                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button fx:id="refreshButton"
                                                text="Refresh"
                                                prefWidth="130.0"
                                                styleClass="secondary-button"
                                                onAction="#handleRefresh"/>
                                    </children>
                                </HBox>

                                <TableView fx:id="counterTableView"
                                           prefHeight="420.0"
                                           maxWidth="Infinity"
                                           maxHeight="Infinity"
                                           VBox.vgrow="ALWAYS">

                                    <columns>
                                        <TableColumn fx:id="parkNameColumn"
                                                     text="Park"
                                                     prefWidth="280.0"/>

                                        <TableColumn fx:id="currentVisitorsColumn"
                                                     text="Current Visitors"
                                                     prefWidth="210.0"/>

                                        <TableColumn fx:id="maxCapacityColumn"
                                                     text="Max Capacity"
                                                     prefWidth="190.0"/>

                                        <TableColumn fx:id="availablePlacesColumn"
                                                     text="Available Places"
                                                     prefWidth="210.0"/>
                                    </columns>
                                </TableView>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER" prefHeight="70.0">
                    <children>
                        <Label fx:id="statusLabel"
                               text="Status: Ready"
                               wrapText="true"
                               styleClass="status-label"/>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>