<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.RegisterSubscriberController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="900.0"
                    prefHeight="720.0"
                    minWidth="760.0"
                    minHeight="620.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="18.0"
                      styleClass="page-container">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Register Subscriber"
                                       styleClass="page-title"/>

                                <Label text="Create a new family subscriber account"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="520.0"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="14.0"
                              maxWidth="590.0"
                              styleClass="card">

                            <children>

                                <GridPane hgap="18.0" vgap="9.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="185.0" prefWidth="195.0"/>
                                        <ColumnConstraints minWidth="270.0" prefWidth="310.0"/>
                                    </columnConstraints>

                                    <rowConstraints>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                        <RowConstraints minHeight="32.0"/>
                                    </rowConstraints>

                                    <children>
                                        <Label text="First Name:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="0"/>

                                        <TextField fx:id="firstNameField"
                                                   promptText="Enter first name"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="0"/>

                                        <Label text="Last Name:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="1"/>

                                        <TextField fx:id="lastNameField"
                                                   promptText="Enter last name"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="1"/>

                                        <Label text="ID Number:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="2"/>

                                        <TextField fx:id="idNumberField"
                                                   promptText="Enter 9-digit ID number"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="2"/>

                                        <Label text="Phone Number:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="3"/>

                                        <TextField fx:id="phoneField"
                                                   promptText="Enter phone number"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="3"/>

                                        <Label text="Email:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="4"/>

                                        <TextField fx:id="emailField"
                                                   promptText="Enter email address"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="4"/>

                                        <Label text="Family Members Count:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="5"/>

                                        <TextField fx:id="familyMembersCountField"
                                                   promptText="Enter family members count"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="5"/>

                                        <Label text="Payment Method:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="6"/>

                                        <ComboBox fx:id="paymentMethodComboBox"
                                                  promptText="Payment Method"
                                                  prefWidth="310.0"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="6"/>

                                        <Label text="Credit Card Last 4 Digits:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="7"/>

                                        <TextField fx:id="creditCardLast4Field"
                                                   promptText="Required only for credit card"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="7"/>

                                        <Label text="Username:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="8"/>

                                        <TextField fx:id="usernameField"
                                                   promptText="Enter username"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="8"/>

                                        <Label text="Password:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="9"/>

                                        <PasswordField fx:id="passwordField"
                                                       promptText="Enter password"
                                                       GridPane.columnIndex="1"
                                                       GridPane.rowIndex="9"/>

                                        <Label text="Confirm Password:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="10"/>

                                        <PasswordField fx:id="confirmPasswordField"
                                                       promptText="Confirm password"
                                                       GridPane.columnIndex="1"
                                                       GridPane.rowIndex="10"/>
                                    </children>
                                </GridPane>

                                <HBox alignment="CENTER" spacing="14.0">
                                    <children>
                                        <Button text="Register Subscriber"
                                                prefWidth="180.0"
                                                styleClass="primary-button"
                                                onAction="#handleRegisterSubscriber"/>

                                        <Button text="Clear"
                                                prefWidth="120.0"
                                                styleClass="secondary-button"
                                                onAction="#handleClear"/>

                                        <Button text="Back"
                                                prefWidth="120.0"
                                                styleClass="secondary-button"
                                                onAction="#handleBack"/>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER" prefHeight="55.0">
                    <children>
                        <Label fx:id="messageLabel"
                               text=""
                               wrapText="true"
                               maxWidth="520.0"
                               styleClass="info-label"/>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>
