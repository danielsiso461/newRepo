<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.OrderTableDisplayController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="1000.0"
                    prefHeight="700.0"
                    minWidth="650.0"
                    minHeight="500.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="page-container"
                      maxWidth="1.7976931348623157E308"
                      maxHeight="1.7976931348623157E308">

                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label text="My Orders" styleClass="page-title"/>
                                <Label text="View your existing orders and choose an action"
                                       styleClass="page-subtitle"/>
                            </children>
                        </VBox>

                        <VBox spacing="16.0"
                              maxWidth="1.7976931348623157E308"
                              maxHeight="1.7976931348623157E308"
                              styleClass="card"
                              VBox.vgrow="ALWAYS">

                            <children>
                                <TableView fx:id="orderTable"
                                           prefHeight="430.0"
                                           maxWidth="1.7976931348623157E308"
                                           maxHeight="1.7976931348623157E308"
                                           VBox.vgrow="ALWAYS">

                                    <columns>
                                        <TableColumn fx:id="orderNumber"
                                                     prefWidth="130.0"
                                                     text="Order Number"/>

                                        <TableColumn fx:id="orderId"
                                                     prefWidth="110.0"
                                                     text="Order ID"/>

                                        <TableColumn fx:id="orderDate"
                                                     prefWidth="130.0"
                                                     text="Order Date"/>

                                        <TableColumn fx:id="visitorNumber"
                                                     prefWidth="120.0"
                                                     text="Visitors"/>

                                        <TableColumn fx:id="confCode"
                                                     prefWidth="160.0"
                                                     text="Confirmation Code"/>

                                        <TableColumn fx:id="userId"
                                                     prefWidth="130.0"
                                                     text="User ID"/>

                                        <TableColumn fx:id="placementDate"
                                                     prefWidth="140.0"
                                                     text="Placement Date"/>

                                        <TableColumn fx:id="orderStatus"
                                                     prefWidth="120.0"
                                                     text="Status"/>
                                    </columns>
                                </TableView>

                                <HBox alignment="CENTER" spacing="18.0">
                                    <children>
                                        <Button fx:id="updateButton"
                                                text="Update Order"
                                                prefWidth="160.0"
                                                styleClass="secondary-button"
                                                onAction="#updateButtonClick"/>

                                        <Button fx:id="makeOrderButton"
                                                text="Make New Order"
                                                prefWidth="180.0"
                                                styleClass="primary-button"
                                                onAction="#makeOrderButtonClick"/>

                                        <Button fx:id="cancelButton"
                                                text="Cancel Order"
                                                prefWidth="160.0"
                                                styleClass="secondary-button"
                                                onAction="#cancelButtonClick"/>

                                        <Button fx:id="waitingListButton"
                                                text="My Waiting List"
                                                prefWidth="160.0"
                                                styleClass="secondary-button"
                                                onAction="#waitingListButtonClick"/>
                                                
                                        <Button fx:id="backButton"
        										text="Back"
        										prefWidth="120.0"
        										styleClass="secondary-button"
        										onAction="#backButtonClick"/>        
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Label fx:id="notifLabel"
                               text=""
                               visible="false"
                               managed="false"
                               styleClass="status-label"/>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>