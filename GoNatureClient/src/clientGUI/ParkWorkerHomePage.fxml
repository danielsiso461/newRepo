<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.ParkWorkerHomePageController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="800.0"
                    prefHeight="550.0"
                    minWidth="650.0"
                    minHeight="500.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="58.0"
                      style="-fx-padding: 16 24 0 24;">
                    <children>
                        <Button text="Logout"
                                prefWidth="110.0"
                                styleClass="danger-button"
                                onAction="#handleLogout"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="page-container">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Park Worker Dashboard"
                                       styleClass="page-title"/>

                                <Label fx:id="welcomeLabel"
                                       text="Welcome"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="430.0"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="14.0"
                              maxWidth="380.0"
                              styleClass="content-card">
                            <children>
                                <Button text="Check Visitor Entry"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleCheckVisitorEntry" />

                                <Button text="Handle Walk-In Visitor"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleWalkInVisitor" />

                                <Button text="Record Visitor Exit"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleRecordVisitorExit" />
                                        
                                <Button text="Entry Payment Receipt"
        								prefWidth="190.0"
        								styleClass="primary-button"
        								mnemonicParsing="false"
        								onAction="#handleEntryPaymentReceipt" />

                                <Button text="View Park Occupancy"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleViewParkOccupancy" />

                                <Button text="My Details"
                                        prefWidth="190.0"
                                        styleClass="secondary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleMyDetails" />

                                <Button text="Logout"
                                        prefWidth="190.0"
                                        styleClass="secondary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleLogout" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>