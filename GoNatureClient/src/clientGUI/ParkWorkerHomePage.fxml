<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.ParkWorkerHomePageController"
            stylesheets="@gonature-theme.css"
            styleClass="page-background">

    <children>
        <BorderPane prefWidth="700.0"
                    prefHeight="450.0"
                    minWidth="650.0"
                    minHeight="420.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="card-container"
                      maxWidth="1.7976931348623157E308"
                      maxHeight="1.7976931348623157E308">

                    <children>
                        <VBox alignment="CENTER" spacing="10.0" styleClass="page-header">
                            <children>
                                <Label text="Park Worker Dashboard"
                                       styleClass="page-title" />

                                <Label fx:id="welcomeLabel"
                                       text="Welcome"
                                       styleClass="page-subtitle" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="14.0"
                              maxWidth="380.0"
                              styleClass="content-card">
                            <children>
                                <Button text="Check Visitor Entry"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleCheckVisitorEntry" />

                                <Button text="Handle Walk-In Visitor"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleWalkInVisitor" />

                                <Button text="Record Visitor Exit"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleRecordVisitorExit" />

                                <Button text="View Park Occupancy"
                                        prefWidth="190.0"
                                        styleClass="primary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleViewParkOccupancy" />

                                <Button text="My Details"
                                        prefWidth="190.0"
                                        styleClass="secondary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleMyDetails" />

                                <Button text="Logout"
                                        prefWidth="190.0"
                                        styleClass="secondary-button"
                                        mnemonicParsing="false"
                                        onAction="#handleLogout" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>