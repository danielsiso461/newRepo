<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="724.0" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGUI.ParkSelectionPageController">

    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="20.0">

            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>

            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Available Parks" />

            <Label style="-fx-font-size: 14px;" text="Choose a park for your order" />

            <TableView fx:id="parksTable" prefHeight="281.0" prefWidth="699.0">

                <columns>
                    <TableColumn fx:id="parkIdColumn" prefWidth="90.0" text="Park ID" />

                    <TableColumn fx:id="parkNameColumn" prefWidth="260.0" text="Park Name" />

                    <TableColumn fx:id="estimatedDurationColumn" prefWidth="170.0" text="Estimated Duration" />

                    <TableColumn fx:id="fullEntryPriceColumn" prefWidth="150.0" text="Full Entry Price" />
                </columns>
            </TableView>

            <HBox spacing="10.0">
                <children>
                    <Button fx:id="refreshButton" onAction="#refreshParks" prefWidth="130.0" text="Refresh Parks" />

                    <Button fx:id="selectParkButton" onAction="#selectPark" prefWidth="130.0" text="Select Park" />

                    <Button fx:id="backButton" onAction="#goBack" prefWidth="100.0" text="Back" />
                </children>
            </HBox>

            <Label fx:id="messageLabel" style="-fx-text-fill: red;" text="" />

        </VBox>
    </children>
</AnchorPane>
