<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.DepartmentManagerHomePageController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="800.0"
                    prefHeight="550.0"
                    minWidth="650.0"
                    minHeight="500.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="58.0"
                      style="-fx-padding: 16 24 0 24;">
                    <children>
                        <Button text="Logout"
                                prefWidth="110.0"
                                styleClass="danger-button"
                                onAction="#handleLogout"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="page-container">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Department Manager Dashboard"
                                       styleClass="page-title"/>

                                <Label text="Welcome"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="460.0"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="14.0"
                              maxWidth="380.0"
                              styleClass="content-card">

                            <children>
                                <Button text="View Reports"
                                        prefWidth="200.0"
                                        mnemonicParsing="false"
                                        styleClass="primary-button"
                                        onAction="#handleViewReports" />

                                <Button text="Approve Park Requests"
                                        prefWidth="200.0"
                                        mnemonicParsing="false"
                                        styleClass="primary-button"
                                        onAction="#handleApproveParkRequests" />

                                <Button text="View Parks Occupancy"
                                        prefWidth="200.0"
                                        mnemonicParsing="false"
                                        styleClass="primary-button"
                                        onAction="#handleViewParksOccupancy" />

                                <Button text="View User Information"
                                        prefWidth="200.0"
                                        mnemonicParsing="false"
                                        styleClass="secondary-button"
                                        onAction="#handleViewUserInformation" />

                                <Button text="Logout"
                                        prefWidth="200.0"
                                        mnemonicParsing="false"
                                        styleClass="secondary-button"
                                        onAction="#handleLogout" />
                            </children>

                        </VBox>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>