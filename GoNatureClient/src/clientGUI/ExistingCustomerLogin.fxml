<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.ExistingCustomerLoginController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="800.0"
                    prefHeight="550.0"
                    minWidth="650.0"
                    minHeight="500.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="58.0"
                      style="-fx-padding: 16 24 0 24;">
                    <children>
                        <Button text="Back"
                                prefWidth="110.0"
                                styleClass="back-button"
                                onAction="#handleBack"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="page-container">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Existing Customer Login"
                                       styleClass="page-title"/>

                                <Label text="Please enter your customer credentials"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="420.0"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="18.0"
                              maxWidth="500.0"
                              styleClass="card">

                            <children>

                                <GridPane hgap="18.0" vgap="14.0">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120.0" prefWidth="130.0"/>
                                        <ColumnConstraints minWidth="260.0" prefWidth="300.0"/>
                                    </columnConstraints>

                                    <rowConstraints>
                                        <RowConstraints minHeight="38.0"/>
                                        <RowConstraints minHeight="38.0"/>
                                    </rowConstraints>

                                    <children>
                                        <Label text="Username:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="0"/>

                                        <TextField fx:id="usernameField"
                                                   prefWidth="300.0"
                                                   promptText="Enter username"
                                                   GridPane.columnIndex="1"
                                                   GridPane.rowIndex="0"/>

                                        <Label text="Password:"
                                               styleClass="field-label"
                                               GridPane.columnIndex="0"
                                               GridPane.rowIndex="1"/>

                                        <PasswordField fx:id="passwordField"
                                                       prefWidth="300.0"
                                                       promptText="Enter password"
                                                       GridPane.columnIndex="1"
                                                       GridPane.rowIndex="1"/>
                                    </children>
                                </GridPane>

                                <Button text="Login"
                                        prefWidth="220.0"
                                        styleClass="primary-button"
                                        onAction="#handleLogin"/>

                                <Label fx:id="messageLabel"
                                       text=""
                                       wrapText="true"
                                       maxWidth="430.0"
                                       styleClass="error-label"/>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>