<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="clientGUI.ParkParameterApprovalPageController"
            stylesheets="@park-parameters.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="1150.0"
                    prefHeight="760.0"
                    minWidth="900.0"
                    minHeight="620.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox styleClass="page-container" BorderPane.alignment="CENTER">
                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label fx:id="headerLabel"
                                       text="Park Parameter Change Approval"
                                       styleClass="page-title"/>

                                <Label fx:id="subHeaderLabel"
                                       text="Review pending park parameter change requests"
                                       wrapText="true"
                                       textAlignment="CENTER"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="650.0"/>
                            </children>
                        </VBox>

                        <VBox styleClass="card, table-card">
                            <children>
                                <TableView fx:id="requestsTableView"
                                           prefHeight="360.0"
                                           minHeight="300.0">
                                    <columns>
                                        <TableColumn fx:id="requestIdColumn"
                                                     text="Request ID"
                                                     prefWidth="95.0"/>
                                        <TableColumn fx:id="parkIdColumn"
                                                     text="Park ID"
                                                     prefWidth="85.0"/>
                                        <TableColumn fx:id="requestedByColumn"
                                                     text="Requested By"
                                                     prefWidth="125.0"/>
                                        <TableColumn fx:id="parameterColumn"
                                                     text="Parameter"
                                                     prefWidth="260.0"/>
                                        <TableColumn fx:id="oldValueColumn"
                                                     text="Current Value"
                                                     prefWidth="135.0"/>
                                        <TableColumn fx:id="newValueColumn"
                                                     text="Requested Value"
                                                     prefWidth="145.0"/>
                                        <TableColumn fx:id="statusColumn"
                                                     text="Status"
                                                     prefWidth="120.0"/>
                                    </columns>
                                </TableView>

                                <Region prefHeight="8.0"/>

                                <Label text="Review note" styleClass="field-label"/>

                                <TextArea fx:id="reviewNoteArea"
                                          prefRowCount="4"
                                          wrapText="true"
                                          promptText="Optional note for approval or rejection"/>

                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button fx:id="refreshButton"
                                                text="Refresh List"
                                                prefWidth="140.0"
                                                styleClass="secondary-button"
                                                onAction="#handleRefresh"/>

                                        <Button fx:id="approveButton"
                                                text="Approve Request"
                                                prefWidth="165.0"
                                                styleClass="primary-button"
                                                onAction="#handleApprove"/>

                                        <Button fx:id="rejectButton"
                                                text="Reject Request"
                                                prefWidth="165.0"
                                                styleClass="danger-button"
                                                onAction="#handleReject"/>
                                                
                                        <Button text="Back"
        										prefWidth="120.0"
        										styleClass="secondary-button"
        										onAction="#handleBack"/>        
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER" prefHeight="60.0">
                    <children>
                        <Label fx:id="statusLabel"
                               text="Status: Ready"
                               styleClass="status-label"/>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>