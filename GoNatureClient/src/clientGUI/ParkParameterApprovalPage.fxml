<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.ParkParameterApprovalPageController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="1150.0"
                    prefHeight="760.0"
                    minWidth="900.0"
                    minHeight="620.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="58.0"
                      style="-fx-padding: 16 24 0 24;">
                    <children>
                        <Button text="Back"
                                prefWidth="110.0"
                                styleClass="back-button"
                                onAction="#handleBack"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER"
                      spacing="22.0"
                      styleClass="page-container"
                      maxWidth="Infinity"
                      maxHeight="Infinity">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label fx:id="headerLabel"
                                       text="Park Parameter Change Approval"
                                       styleClass="page-title"/>

                                <Label fx:id="subHeaderLabel"
                                       text="Review pending park parameter change requests"
                                       wrapText="true"
                                       textAlignment="CENTER"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="650.0"/>
                            </children>
                        </VBox>

                        <VBox spacing="16.0"
                              maxWidth="1050.0"
                              maxHeight="Infinity"
                              styleClass="card"
                              VBox.vgrow="ALWAYS">

                            <children>
                                <TableView fx:id="requestsTableView"
                                           prefHeight="340.0"
                                           minHeight="280.0"
                                           maxWidth="Infinity"
                                           maxHeight="Infinity"
                                           VBox.vgrow="ALWAYS">

                                    <columns>
                                        <TableColumn fx:id="requestIdColumn"
                                                     text="Req ID"
                                                     prefWidth="80.0"/>

                                        <TableColumn fx:id="parkIdColumn"
                                                     text="Park ID"
                                                     prefWidth="80.0"/>


                                        <TableColumn fx:id="parameterColumn"
                                                     text="Parameter"
                                                     prefWidth="250.0"/>

                                        <TableColumn fx:id="oldValueColumn"
                                                     text="Current"
                                                     prefWidth="130.0"/>

                                        <TableColumn fx:id="newValueColumn"
                                                     text="Requested"
                                                     prefWidth="140.0"/>

                                        <TableColumn fx:id="statusColumn"
                                                     text="Status"
                                                     prefWidth="100.0"/>
                                    </columns>
                                </TableView>

                                <Region prefHeight="6.0"/>

                                <Label text="Review Note"
                                       styleClass="field-label"/>

                                <TextArea fx:id="reviewNoteArea"
                                          prefRowCount="4"
                                          wrapText="true"
                                          maxWidth="Infinity"
                                          promptText="Optional note for approval or rejection"/>

                                <Region prefHeight="6.0"/>

                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button fx:id="refreshButton"
                                                text="Refresh List"
                                                prefWidth="140.0"
                                                styleClass="secondary-button"
                                                onAction="#handleRefresh"/>

                                        <Button fx:id="approveButton"
                                                text="Approve Request"
                                                prefWidth="165.0"
                                                styleClass="primary-button"
                                                onAction="#handleApprove"/>

                                        <Button fx:id="rejectButton"
                                                text="Reject Request"
                                                prefWidth="165.0"
                                                styleClass="danger-button"
                                                onAction="#handleReject"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER" prefHeight="70.0">
                    <children>
                        <Label fx:id="statusLabel"
                               text="Status: Ready"
                               wrapText="true"
                               styleClass="status-label"/>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>