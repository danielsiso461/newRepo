               </font>
            </Label>
            <Label layoutX="106.0" layoutY="120.0" text="Subscriber ID:" />
            <TextField fx:id="subscriberIdField" layoutX="296.0" layoutY="116.0" promptText="Enter subscriber ID" />
            <Button fx:id="searchSubscriberBtn" layoutX="476.0" layoutY="116.0" mnemonicParsing="false" onAction="#handleSearchSubscriber" text="Search Subscriber" />
            <Label layoutX="107.0" layoutY="172.0" text="Subscriber Details">
               <font>
                  <Font name="System Italic" size="18.0" />
               </font>
            </Label>
            <Label layoutX="107.0" layoutY="211.0" text="Name:" />
            <Label layoutX="107.0" layoutY="246.0" text="Email:" />
