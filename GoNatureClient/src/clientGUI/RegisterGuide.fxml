            <Label fx:id="subscriberEmailLabel" layoutX="186.0" layoutY="246.0" text="-" />
            <Label layoutX="108.0" layoutY="283.0" text="Guide Details">
               <font>
                  <Font name="System Italic" size="18.0" />
