<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.RegisterGuideController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="900.0"
                    prefHeight="700.0"
                    minWidth="760.0"
                    minHeight="580.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="58.0"
                      style="-fx-padding: 16 24 0 24;">
                    <children>
                        <Button fx:id="backBtn"
                                text="Back"
                                prefWidth="110.0"
                                styleClass="back-button"
                                onAction="#handleBack"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="page-container">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Register Guide"
                                       styleClass="page-title"/>

                                <Label text="Search a subscriber and register them as a guide"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="520.0"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="20.0"
                              maxWidth="650.0"
                              styleClass="card">

                            <children>

                                <VBox spacing="12.0">
                                    <children>
                                        <Label text="Subscriber Search"
                                               styleClass="section-title"/>

                                        <HBox alignment="CENTER_LEFT"
                                              spacing="12.0"
                                              styleClass="form-row">
                                            <children>
                                                <Label text="Subscriber ID:"
                                                       minWidth="145.0"
                                                       styleClass="field-label"/>

                                                <TextField fx:id="subscriberIdField"
                                                           prefWidth="240.0"
                                                           promptText="Enter subscriber ID"/>

                                                <Button fx:id="searchSubscriberBtn"
                                                        text="Search"
                                                        prefWidth="120.0"
                                                        styleClass="secondary-button"
                                                        onAction="#handleSearchSubscriber"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Separator prefWidth="560.0"/>

                                <VBox spacing="12.0">
                                    <children>
                                        <Label text="Subscriber Details"
                                               styleClass="section-title"/>

                                        <GridPane hgap="18.0" vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="145.0" prefWidth="150.0"/>
                                                <ColumnConstraints minWidth="300.0" prefWidth="360.0"/>
                                            </columnConstraints>

                                            <rowConstraints>
                                                <RowConstraints minHeight="34.0"/>
                                                <RowConstraints minHeight="34.0"/>
                                            </rowConstraints>

                                            <children>
                                                <Label text="Name:"
                                                       styleClass="field-label"
                                                       GridPane.columnIndex="0"
                                                       GridPane.rowIndex="0"/>

                                                <Label fx:id="subscriberNameLabel"
                                                       text="-"
                                                       styleClass="value-label"
                                                       GridPane.columnIndex="1"
                                                       GridPane.rowIndex="0"/>

                                                <Label text="Email:"
                                                       styleClass="field-label"
                                                       GridPane.columnIndex="0"
                                                       GridPane.rowIndex="1"/>

                                                <Label fx:id="subscriberEmailLabel"
                                                       text="-"
                                                       wrapText="true"
                                                       styleClass="value-label"
                                                       GridPane.columnIndex="1"
                                                       GridPane.rowIndex="1"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <Separator prefWidth="560.0"/>

                                <VBox spacing="12.0">
                                    <children>
                                        <Label text="Guide Details"
                                               styleClass="section-title"/>

                                        <GridPane hgap="18.0" vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="145.0" prefWidth="150.0"/>
                                                <ColumnConstraints minWidth="300.0" prefWidth="360.0"/>
                                            </columnConstraints>

                                            <rowConstraints>
                                                <RowConstraints minHeight="38.0"/>
                                                <RowConstraints minHeight="38.0"/>
                                            </rowConstraints>

                                            <children>
                                                <Label text="Organization:"
                                                       styleClass="field-label"
                                                       GridPane.columnIndex="0"
                                                       GridPane.rowIndex="0"/>

                                                <TextField fx:id="organizationNameField"
                                                           prefWidth="300.0"
                                                           promptText="Organization Name"
                                                           GridPane.columnIndex="1"
                                                           GridPane.rowIndex="0"/>

                                                <Label text="Guide Status:"
                                                       styleClass="field-label"
                                                       GridPane.columnIndex="0"
                                                       GridPane.rowIndex="1"/>

                                                <ComboBox fx:id="guideStatusComboBox"
                                                          prefWidth="300.0"
                                                          promptText="Choose status"
                                                          GridPane.columnIndex="1"
                                                          GridPane.rowIndex="1"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER" spacing="14.0">
                                    <children>
                                        <Button fx:id="registerGuideBtn"
                                                text="Register Guide"
                                                prefWidth="170.0"
                                                styleClass="primary-button"
                                                onAction="#handleRegisterGuide"/>

                                        <Button fx:id="clearBtn"
                                                text="Clear"
                                                prefWidth="130.0"
                                                styleClass="secondary-button"
                                                onAction="#handleClear"/>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER" prefHeight="70.0">
                    <children>
                        <Label fx:id="messageLabel"
                               text="Status: Ready"
                               wrapText="true"
                               styleClass="status-label"/>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>