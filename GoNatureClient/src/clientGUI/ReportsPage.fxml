<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="clientGUI.ReportsPageController">

    <children>
        <BorderPane prefHeight="720.0"
                    prefWidth="1050.0"
                    minHeight="600.0"
                    minWidth="850.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <VBox spacing="15.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="25.0" left="20.0" right="20.0" bottom="10.0"/>
                    </padding>

                    <children>
                        <Label text="Reports and Data Analysis" textAlignment="CENTER">
                            <font>
                                <Font size="24.0"/>
                            </font>
                        </Label>

                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <Label text="Report type:"/>
                                <ComboBox fx:id="reportTypeComboBox"
                                          prefWidth="210.0"
                                          minWidth="170.0"/>

                                <Label text="Park:"/>
                                <ComboBox fx:id="parkComboBox"
                                          prefWidth="220.0"
                                          minWidth="170.0"/>

                                <Label text="Month:"/>
                                <ComboBox fx:id="monthComboBox"
                                          prefWidth="90.0"
                                          minWidth="75.0"/>

                                <Label text="Year:"/>
                                <ComboBox fx:id="yearComboBox"
                                          prefWidth="100.0"
                                          minWidth="85.0"/>

                                <Button fx:id="showReportButton"
                                        text="Show Report"
                                        minWidth="105.0"
                                        onAction="#handleShowReport"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="10.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets top="10.0" left="10.0" right="10.0" bottom="10.0"/>
                    </padding>

                    <children>
                        <PieChart fx:id="reportPieChart"
                                  prefHeight="320.0"
                                  minHeight="220.0"
                                  maxHeight="1.7976931348623157E308"
                                  maxWidth="1.7976931348623157E308"
                                  visible="false"
                                  managed="false"
                                  VBox.vgrow="ALWAYS"/>

                        <BarChart fx:id="reportBarChart"
                                  prefHeight="320.0"
                                  minHeight="220.0"
                                  maxHeight="1.7976931348623157E308"
                                  maxWidth="1.7976931348623157E308"
                                  visible="false"
                                  managed="false"
                                  VBox.vgrow="ALWAYS">
                            <xAxis>
                                <CategoryAxis fx:id="barChartXAxis"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="barChartYAxis"/>
                            </yAxis>
                        </BarChart>

                        <TableView fx:id="reportsTableView"
                                   prefHeight="240.0"
                                   minHeight="180.0"
                                   maxHeight="1.7976931348623157E308"
                                   maxWidth="1.7976931348623157E308"
                                   VBox.vgrow="ALWAYS"/>
                    </children>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER" prefHeight="45.0" minHeight="40.0">
                    <children>
                        <Label fx:id="statusLabel" text="Status: Ready"/>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>