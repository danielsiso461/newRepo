<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="clientGUI.ReportsPageController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefHeight="760.0"
                    prefWidth="1150.0"
                    minHeight="620.0"
                    minWidth="900.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER" spacing="22.0" styleClass="page-container">
                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label text="Reports and Data Analysis" styleClass="page-title"/>
                                <Label text="Select report type, park and date filters"
                                       styleClass="page-subtitle"/>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER" spacing="12.0" maxWidth="980.0" styleClass="card">
                            <children>
                                <Label text="Report type:" styleClass="field-label"/>
                                <ComboBox fx:id="reportTypeComboBox" prefWidth="210.0"/>

                                <Label text="Park:" styleClass="field-label"/>
                                <ComboBox fx:id="parkComboBox" prefWidth="220.0"/>

                                <Label text="Month:" styleClass="field-label"/>
                                <ComboBox fx:id="monthComboBox" prefWidth="90.0"/>

                                <Label text="Year:" styleClass="field-label"/>
                                <ComboBox fx:id="yearComboBox" prefWidth="100.0"/>

                                <Button fx:id="showReportButton"
                                        text="Show Report"
                                        prefWidth="130.0"
                                        styleClass="primary-button"
                                        onAction="#handleShowReport"/>
                            </children>
                        </HBox>

                        <VBox spacing="14.0" maxWidth="1050.0" styleClass="card">
                            <children>
                                <PieChart fx:id="reportPieChart"
                                          prefHeight="300.0"
                                          visible="false"
                                          managed="false"/>

                                <BarChart fx:id="reportBarChart"
                                          prefHeight="300.0"
                                          visible="false"
                                          managed="false">
                                    <xAxis>
                                        <CategoryAxis fx:id="barChartXAxis"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="barChartYAxis"/>
                                    </yAxis>
                                </BarChart>

                                <TableView fx:id="reportsTableView"
                                           prefHeight="230.0"/>
                            </children>
                        </VBox>

                        <Label fx:id="statusLabel"
                               text="Status: Ready"
                               styleClass="status-label"/>
                               
                        <Button text="Back"
        						prefWidth="120.0"
        						styleClass="secondary-button"
        						onAction="#handleBack"/>       
                               
                               

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>