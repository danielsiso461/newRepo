<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.EntryPaymentPageController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="900.0"
                    prefHeight="700.0"
                    minWidth="750.0"
                    minHeight="560.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="58.0"
                      style="-fx-padding: 16 24 0 24;">
                    <children>
                        <Button text="Back"
                                prefWidth="110.0"
                                styleClass="back-button"
                                onAction="#handleBack"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      styleClass="page-container"
                      maxWidth="Infinity"
                      maxHeight="Infinity">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Entry Payment Receipt"
                                       styleClass="page-title"/>

                                <Label text="Enter order number to calculate the park entry payment"
                                       styleClass="page-subtitle"/>

                                <Separator prefWidth="520.0"/>
                            </children>
                        </VBox>

                        <VBox spacing="18.0"
                              maxWidth="780.0"
                              maxHeight="Infinity"
                              styleClass="card">

                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <Label text="Order Number"
                                               minWidth="130.0"
                                               styleClass="field-label"/>

                                        <TextField fx:id="orderNumberField"
                                                   promptText="Enter order number"
                                                   prefWidth="260.0"/>

                                        <Button fx:id="calculateButton"
                                                text="Calculate Price"
                                                prefWidth="170.0"
                                                styleClass="primary-button"
                                                onAction="#handleCalculatePrice"/>
                                    </children>
                                </HBox>

                                <TextArea fx:id="receiptTextArea"
                                          editable="false"
                                          wrapText="false"
                                          prefHeight="390.0"
                                          maxWidth="Infinity"
                                          promptText="Receipt will appear here..."
                                          styleClass="receipt-area"/>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

            <bottom>
                <HBox alignment="CENTER" prefHeight="70.0">
                    <children>
                        <Label fx:id="statusLabel"
                               text="Status: Ready"
                               wrapText="true"
                               styleClass="status-label, status-info"/>
                    </children>
                </HBox>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>