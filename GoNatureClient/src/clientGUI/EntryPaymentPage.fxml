<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGUI.EntryPaymentPageController"
            stylesheets="@gonature-theme.css">

    <styleClass>
        <String fx:value="root-pane"/>
    </styleClass>

    <children>
        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="24.0"
                      maxWidth="900.0">

                    <styleClass>
                        <String fx:value="page-container"/>
                    </styleClass>

                    <padding>
                        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
                    </padding>

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Entry Payment Receipt">
                                    <styleClass>
                                        <String fx:value="page-title"/>
                                    </styleClass>
                                </Label>

                                <Label text="Enter order number to calculate the park entry payment">
                                    <styleClass>
                                        <String fx:value="page-subtitle"/>
                                    </styleClass>
                                </Label>
                            </children>
                        </VBox>

                        <VBox spacing="18.0"
                              maxWidth="760.0">

                            <styleClass>
                                <String fx:value="card"/>
                            </styleClass>

                            <padding>
                                <Insets top="26.0" right="30.0" bottom="26.0" left="30.0"/>
                            </padding>

                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <Label text="Order Number" minWidth="120.0">
                                            <styleClass>
                                                <String fx:value="field-label"/>
                                            </styleClass>
                                        </Label>

                                        <TextField fx:id="orderNumberField"
                                                   promptText="Enter order number"
                                                   prefWidth="260.0"/>

                                        <Button fx:id="calculateButton"
                                                text="Calculate Price"
                                                prefWidth="170.0"
                                                onAction="#handleCalculatePrice">
                                            <styleClass>
                                                <String fx:value="primary-button"/>
                                            </styleClass>
                                        </Button>
                                    </children>
                                </HBox>

                                <TextArea fx:id="receiptTextArea"
                                          editable="false"
                                          wrapText="false"
                                          prefHeight="390.0"
                                          promptText="Receipt will appear here...">
                                    <styleClass>
                                        <String fx:value="receipt-area"/>
                                    </styleClass>
                                </TextArea>

                            </children>
                        </VBox>

                        <Label fx:id="statusLabel"
                               text="Status: Ready">
                            <styleClass>
                                <String fx:value="status-label"/>
                                <String fx:value="status-info"/>
                            </styleClass>
                        </Label>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>