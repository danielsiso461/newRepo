<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="clientGUI.ParkParameterRequestPageController"
            stylesheets="@park-parameters.css">

    <styleClass>
        <String fx:value="root-pane"/>
    </styleClass>

    <children>
        <BorderPane prefWidth="1000.0"
                    prefHeight="700.0"
                    minWidth="900.0"
                    minHeight="620.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER" spacing="24.0" BorderPane.alignment="CENTER">
                    <styleClass>
                        <String fx:value="page-container"/>
                    </styleClass>

                    <children>

                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label fx:id="headerLabel"
                                       text="Park Parameter Update Request">
                                    <styleClass>
                                        <String fx:value="page-title"/>
                                    </styleClass>
                                </Label>

                                <Label fx:id="subHeaderLabel"
                                       text="Submit a request to update one of your park's operating parameters"
                                       wrapText="true"
                                       textAlignment="CENTER">
                                    <styleClass>
                                        <String fx:value="page-subtitle"/>
                                    </styleClass>
                                </Label>

                                <Separator prefWidth="540.0"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER"
                              spacing="18.0"
                              maxWidth="560.0">
                            <styleClass>
                                <String fx:value="card"/>
                                <String fx:value="form-card"/>
                            </styleClass>

                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="16.0">
                                    <styleClass>
                                        <String fx:value="form-row"/>
                                    </styleClass>

                                    <children>
                                        <Label text="Park" minWidth="185.0">
                                            <styleClass>
                                                <String fx:value="field-label"/>
                                            </styleClass>
                                        </Label>

                                        <ComboBox fx:id="parkComboBox" prefWidth="300.0"/>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="16.0">
                                    <styleClass>
                                        <String fx:value="form-row"/>
                                    </styleClass>

                                    <children>
                                        <Label text="Parameter" minWidth="185.0">
                                            <styleClass>
                                                <String fx:value="field-label"/>
                                            </styleClass>
                                        </Label>

                                        <ComboBox fx:id="parameterComboBox" prefWidth="300.0"/>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="16.0">
                                    <styleClass>
                                        <String fx:value="form-row"/>
                                    </styleClass>

                                    <children>
                                        <Label text="Current value" minWidth="185.0">
                                            <styleClass>
                                                <String fx:value="field-label"/>
                                            </styleClass>
                                        </Label>

                                        <Label fx:id="currentValueLabel" text="Current value: -">
                                            <styleClass>
                                                <String fx:value="value-label"/>
                                            </styleClass>
                                        </Label>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="16.0">
                                    <styleClass>
                                        <String fx:value="form-row"/>
                                    </styleClass>

                                    <children>
                                        <Label text="Requested new value" minWidth="185.0">
                                            <styleClass>
                                                <String fx:value="field-label"/>
                                            </styleClass>
                                        </Label>

                                        <TextField fx:id="newValueField"
                                                   prefWidth="300.0"
                                                   promptText="Enter a new value"/>
                                    </children>
                                </HBox>

                                <Region prefHeight="6.0"/>

                                <Button fx:id="submitButton"
                                        text="Submit Update Request"
                                        prefWidth="240.0"
                                        onAction="#handleSubmitRequest">
                                    <styleClass>
                                        <String fx:value="primary-button"/>
                                    </styleClass>
                                </Button>
                                
                                <Button text="Back"
        								prefWidth="160.0"
        								onAction="#handleBack">
    								<styleClass>
      									<String fx:value="secondary-button"/>
    								</styleClass>
								</Button>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER">
                            <children>
                                <Label fx:id="statusLabel"
                                       text="Status: Ready">
                                    <styleClass>
                                        <String fx:value="status-label"/>
                                        <String fx:value="status-info"/>
                                    </styleClass>
                                </Label>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>