<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clientGUI.OccasionalCustomerAccessController">
   <children>
      <AnchorPane layoutX="-7.0" layoutY="-8.0" prefHeight="400.0" prefWidth="700.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Label layoutX="166.0" layoutY="50.0" text="Occasional Customer Access">
               <font>
                  <Font name="System Bold Italic" size="28.0" />
               </font>
            </Label>
            <Label layoutX="166.0" layoutY="127.0" text="Please enter your order number" />
            <TextField fx:id="orderNumberField" layoutX="386.0" layoutY="123.0" promptText="Enter order number" />
            <Label fx:id="messageLabel" layoutX="203.0" layoutY="183.0" minWidth="300.0" prefHeight="17.0" prefWidth="300.0" />
            <Button layoutX="222.0" layoutY="257.0" mnemonicParsing="false" onAction="#handleContinue" text="Continue" />
            <Button layoutX="409.0" layoutY="257.0" mnemonicParsing="false" onAction="#handleBack" text="Back" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
