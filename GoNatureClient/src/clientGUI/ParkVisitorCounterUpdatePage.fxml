            <Button layoutX="335.0" layoutY="308.0" mnemonicParsing="false" onAction="#handleLogout" text="Logout" />
            <Button layoutX="304.0" layoutY="175.0" mnemonicParsing="false" onAction="#handleWalkInVisitor" text="Handle Walk-In Visitor" />
