<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21.0.9"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="serverGUI.DBPasswordController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="620.0"
                    prefHeight="420.0"
                    minWidth="520.0"
                    minHeight="340.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER" spacing="24.0" styleClass="page-container">
                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="Database Connection" styleClass="page-title"/>
                                <Label text="Enter the database password to start the server"
                                       styleClass="page-subtitle"/>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="18.0" maxWidth="430.0" styleClass="card">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="14.0">
                                    <children>
                                        <Label fx:id="lableID"
                                               text="DB password:"
                                               minWidth="120.0"
                                               styleClass="field-label"/>

                                        <PasswordField fx:id="textID"
                                                       prefWidth="230.0"
                                                       promptText="Password"/>
                                    </children>
                                </HBox>

                                <Button fx:id="buttonID"
                                        text="Connect"
                                        prefWidth="160.0"
                                        styleClass="primary-button"
                                        onAction="#handleSend"/>

                                <Label fx:id="errorLabel"
                                       text="Wrong DB password"
                                       visible="false"
                                       styleClass="error-label"/>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>