<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="serverGUI.ClientConnectionTableController"
            stylesheets="@gonature-theme.css"
            styleClass="root-pane">

    <children>
        <BorderPane prefWidth="1100.0"
                    prefHeight="760.0"
                    minWidth="700.0"
                    minHeight="520.0"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <center>
                <VBox alignment="CENTER"
                      spacing="22.0"
                      styleClass="page-container"
                      maxWidth="1.7976931348623157E308"
                      maxHeight="1.7976931348623157E308">

                    <children>

                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Label text="GoNature Server" styleClass="page-title"/>
                                <Label fx:id="hostNameLabel" styleClass="page-subtitle"/>
                               <Label fx:id="ipAddressLabel" styleClass="status-label"/>
                            </children>
                        </VBox>

                        <VBox spacing="16.0"
                              styleClass="card"
                              maxWidth="1.7976931348623157E308"
                              maxHeight="1.7976931348623157E308"
                              VBox.vgrow="ALWAYS">

                            <children>
                                <TableView fx:id="userTable"
                                           prefHeight="390.0"
                                           maxHeight="1.7976931348623157E308"
                                           maxWidth="1.7976931348623157E308"
                                           VBox.vgrow="ALWAYS">

                                    <columns>
                                        <TableColumn fx:id="userNumber"
                                                     editable="false"
                                                     prefWidth="160.0"
                                                     text="User Number"/>

                                        <TableColumn fx:id="userId"
                                                     editable="false"
                                                     prefWidth="180.0"
                                                     text="User ID"/>

                                        <TableColumn fx:id="userIp"
                                                     editable="false"
                                                     prefWidth="190.0"
                                                     text="User IP"/>

                                        <TableColumn fx:id="hostName"
                                                     editable="false"
                                                     prefWidth="260.0"
                                                     text="Host Name"/>

                                        <TableColumn fx:id="status"
                                                     editable="false"
                                                     prefWidth="200.0"
                                                     text="Status"/>
                                    </columns>
                                </TableView>

                                <Label text="Server Log" styleClass="section-title"/>

                                <TextArea fx:id="serverLogArea"
                                          prefHeight="150.0"
                                          maxWidth="1.7976931348623157E308"
                                          editable="false"
                                          wrapText="true"
                                          promptText="Server actions will appear here..."/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>